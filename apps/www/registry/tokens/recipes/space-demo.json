{
  "space": {
    "$type": "dimension",
    "$extensions": {
      "sh.sugarcube": {
        "scale": {
          "mode": "multipliers",
          "base": {
            "min": { "value": 0.875, "unit": "rem" },
            "max": { "value": 1, "unit": "rem" }
          },
          "multipliers": {
            "0": 0,
            "3xs": 0.25,
            "2xs": 0.5,
            "xs": 0.75,
            "sm": 1,
            "md": 1.5,
            "lg": 2,
            "xl": 3,
            "2xl": 4,
            "3xl": 6
          },
          "pairs": ["3xs-2xs", "2xs-xs", "xs-sm", "sm-md", "md-lg", "lg-xl", "xl-2xl", "2xl-3xl"]
        }
      }
    }
  }
}
