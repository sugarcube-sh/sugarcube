{
  "size": {
    "$type": "dimension",
    "step": {
      "$extensions": {
        "sh.sugarcube": {
          "scale": {
            "mode": "exponential",
            "base": {
              "min": { "value": 0.875, "unit": "rem" },
              "max": { "value": 1, "unit": "rem" }
            },
            "ratio": { "min": 1.2, "max": 1.3 },
            "steps": { "negative": 2, "positive": 10 }
          }
        }
      }
    }
  }
}
