        "style": "solid",
        "width": "{borderWidth.default}"
      }
    },
    "transparent": {
      "$value": {
        "color": "{borderColor.transparent}",
        "style": "solid",
        "width": "{borderWidth.default}"
      }
    },
    "neutral": {
      "emphasis": {
