{
  "focus": {
    "outline": {
      "$value": {
        "color": "{focus.outlineColor}",
        "style": "solid",
        "width": { "value": 2, "unit": "px" }
      },
      "$type": "border"
    }
  },
  "border": {
    "$type": "border",
    "default": {
      "$value": {
        "color": "{borderColor.default}",
        "style": "solid",
        "width": "{borderWidth.default}"
      }
    },
    "muted": {
      "$value": {
        "color": "{borderColor.muted}",
        "style": "solid",
        "width": "{borderWidth.default}"
      }
    },
    "emphasis": {
      "$value": {
        "color": "{borderColor.emphasis}",
        "style": "solid",
        "width": "{borderWidth.default}"
      }
    },
    "disabled": {
