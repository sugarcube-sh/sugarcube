{
  "boxShadow": {
    "$type": "shadow",
    "thin": {
      "$value": {
        "color": "{borderColor.default}",
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 0, "unit": "px" },
        "blur": { "value": 0, "unit": "px" },
        "spread": "{borderWidth.thin}",
        "inset": true
      },
      "$description": "Thin inset shadow for borders"
    },
    "thick": {
      "$value": {
        "color": "{borderColor.default}",
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 0, "unit": "px" },
        "blur": { "value": 0, "unit": "px" },
        "spread": "{borderWidth.thick}",
        "inset": true
      },
      "$description": "Thick inset shadow for borders"
    },
    "thicker": {
      "$value": {
        "color": "{borderColor.default}",
        "offsetX": { "value": 0, "unit": "px" },
        "offsetY": { "value": 0, "unit": "px" },
        "blur": { "value": 0, "unit": "px" },
        "spread": "{borderWidth.thicker}",
        "inset": true
      },
      "$description": "Thicker inset shadow for borders"
    }
  },
  "borderWidth": {
    "default": {
      "$value": "{borderWidth.thin}"
    },
    "thin": {
      "$value": { "value": 1, "unit": "px" },
      "$type": "dimension"
    },
    "thick": {
      "$value": { "value": 2, "unit": "px" },
      "$type": "dimension"
    },
    "thicker": {
      "$value": { "value": 4, "unit": "px" },
      "$type": "dimension"
    }
  },
  "borderRadius": {
    "small": {
      "$value": { "value": 3, "unit": "px" },
      "$type": "dimension"
    },
    "medium": {
      "$value": { "value": 6, "unit": "px" },
      "$type": "dimension"
    },
    "large": {
      "$value": { "value": 12, "unit": "px" },
      "$type": "dimension"
    },
    "full": {
      "$value": { "value": 9999, "unit": "px" },
      "$type": "dimension",
      "$description": "Use this border radius for pill shaped elements"
    },
    "default": {
      "$value": "{borderRadius.medium}"
    }
  },
  "outline": {
    "focus": {
      "offset": {
        "$value": { "value": -2, "unit": "px" },
        "$type": "dimension"
      },
      "width": {
        "$value": { "value": 2, "unit": "px" },
        "$type": "dimension"
      }
    }
  }
}
