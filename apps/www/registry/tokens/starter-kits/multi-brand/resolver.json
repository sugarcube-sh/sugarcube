{
  "name": "Multi-Brand Starter Kit",
  "description": "Demonstrates multi-brand output with internal theme support",
  "version": "2025.10",
  "sets": {
    "base": {
      "sources": [
        {
          "$ref": "base/tokens.json"
        }
      ]
    }
  },
  "modifiers": {
    "brand": {
      "default": "ocean",
      "contexts": {
        "ocean": [
          {
            "$ref": "brands/ocean/palette.json"
          }
        ],
        "forest": [
          {
            "$ref": "brands/forest/palette.json"
          }
        ]
      }
    },
    "theme": {
      "default": "light",
      "contexts": {
        "light": [],
        "dark": [
          {
            "$ref": "themes/dark.json"
          }
        ],
        "forest-dark": [
          {
            "$ref": "brands/forest/dark.json"
          }
        ]
      }
    }
  },
  "resolutionOrder": [
    {
      "$ref": "#/sets/base"
    },
    {
      "$ref": "#/modifiers/brand"
    },
    {
      "$ref": "#/modifiers/theme"
    }
  ]
}
