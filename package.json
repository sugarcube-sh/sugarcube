{
    "name": "@sugarcube-sh/root",
    "version": "0.0.1",
    "license": "MIT",
    "private": true,
    "author": {
        "name": "Mark Tomlinson",
        "email": "mark@marktomlinson.dev",
        "url": "https://marktomlinson.dev"
    },
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "build": "pnpm --filter='@sugarcube-sh/core' build && pnpm -r --filter='@sugarcube-sh/*' --filter='!@sugarcube-sh/core' build",
        "build:clean": "pnpm clean && pnpm build",
        "ci:install": "pnpm install",
        "ci:version": "changeset version",
        "ci:publish": "changeset publish",
        "ci:prepublish": "pnpm build",
        "clean": "rm -rf packages/*/dist packages/*/.tsbuildinfo node_modules/.cache",
        "deploy:www": "pnpm --filter=www run deploy",
        "dev": "pnpm --filter=!@sugarcube-sh/cli --filter=!studio -r --parallel dev",
        "dev:www": "pnpm --filter=www dev",
        "knip": "knip",
        "lint": "oxlint",
        "lint:fix": "oxlint --fix",
        "test": "pnpm -r --if-present test",
        "type-check": "pnpm -r --if-present type-check"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm lint-staged"
    },
    "lint-staged": {
        "*.{js,ts,mjs,cjs,tsx,jsx,json,jsonc,css,astro}": [
            "pnpm run lint"
        ]
    },
    "devDependencies": {
        "@changesets/cli": "^2.27.9",
        "@types/node": "^24.9.2",
        "@vitest/coverage-istanbul": "^4.0.18",
        "knip": "^6.21.0",
        "lint-staged": "^16.2.7",
        "oxlint": "^1.72.0",
        "simple-git-hooks": "^2.13.1",
        "typescript": "^5.8.3",
        "vitest": "^4.0.18"
    },
    "packageManager": "pnpm@11.5.1"
}
