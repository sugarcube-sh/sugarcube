    "semantic": {
      "description": "Public, intent-driven tokens",
      "sources": [
        {
          "color": {
            "danger": { "$type": "color", "$value": "{rose.600}" }
          }
        }
      ]
    }
  },
  "resolutionOrder": [{ "$ref": "#/sets/raw" }, { "$ref": "#/sets/semantic" }]
}
