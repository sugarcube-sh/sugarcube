{
  "name": "@sugarcube-sh/studio-embed",
  "version": "0.0.1",
  "private": true,
  "description": "<sugarcube-studio> web component for embedding Studio in any page",
  "license": "MIT",
  "author": {
    "name": "Mark Tomlinson",
    "email": "mark@marktomlinson.dev",
    "url": "https://marktomlinson.dev"
  },
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/web-component.d.mts",
      "import": "./dist/web-component.mjs"
    },
    "./path": {
      "types": "./dist/path.d.mts",
      "import": "./dist/path.mjs"
    }
  },
  "scripts": {
    "build": "pkgroll --minify",
    "dev": "pkgroll --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@sugarcube-sh/studio-protocol": "workspace:*"
  },
  "devDependencies": {
    "pkgroll": "^2.26.0",
    "typescript": "^5.8.3"
  }
}
