{
    "name": "@sugarcube-sh/studio-vite",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "description": "Vite plugin for Sugarcube Studio (DevTools dock + dev server)",
    "license": "MIT",
    "author": {
        "name": "Mark Tomlinson",
        "email": "mark@marktomlinson.dev",
        "url": "https://marktomlinson.dev"
    },
    "exports": {
